# ===========================================
# Authorship Receipt - Environment Variables
# ===========================================

# Application
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3000/api

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/authorship_receipt

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
# Or use full URL:
# REDIS_URL=redis://localhost:6379

# Worker
WORKER_PORT=3001
WORKER_URL=http://localhost:3001
ANALYSIS_QUEUE_NAME=authorship-analysis
WORKER_CONCURRENCY=3
JOB_MAX_ATTEMPTS=3

# Auth
# Generate with: openssl rand -hex 32
AUTH_SECRET=your-auth-secret-here

# Storage (S3 or compatible)
# STORAGE_BUCKET=authorship-receipt-uploads
# STORAGE_REGION=us-east-1
# STORAGE_ACCESS_KEY=your-access-key
# STORAGE_SECRET_KEY=your-secret-key

# Storage - Local dev
STORAGE_LOCAL_DIR=/tmp/authorship-receipt/uploads
# STORAGE_S3_BUCKET=your-bucket
# STORAGE_S3_REGION=us-east-1

# Worker
WORKER_PORT=3001

# Optional: Analytics
# ANALYTICS_ID=your-analytics-id
