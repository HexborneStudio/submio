# ===========================================
# Authorship Receipt - Environment Variables
# ===========================================

# Application
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3000/api

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/authorship_receipt

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# Auth (configure as needed)
# AUTH_SECRET=your-auth-secret-here
# MAGIC_LINK_SECRET=your-magic-link-secret-here

# Storage (S3 or compatible)
# STORAGE_BUCKET=authorship-receipt-uploads
# STORAGE_REGION=us-east-1
# STORAGE_ACCESS_KEY=your-access-key
# STORAGE_SECRET_KEY=your-secret-key

# Worker
WORKER_PORT=3001

# Optional: Analytics
# ANALYTICS_ID=your-analytics-id
